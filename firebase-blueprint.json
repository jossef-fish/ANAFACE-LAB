{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Private user profile data including PII.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the platform" }
      },
      "required": ["uid", "email", "createdAt", "role"]
    },
    "FaceAnalysis": {
      "title": "Face Analysis Result",
      "description": "A record of a facial analysis performed by the AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "imageUrl": { "type": "string", "format": "uri", "description": "The analyzed image URL" },
        "overallScore": { "type": "number", "description": "Total attractiveness score" },
        "features": { "type": "object", "description": "Detailed feature scores" },
        "improvementTips": { "type": "array", "items": { "type": "string" }, "description": "AI-generated tips" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Analysis timestamp" }
      },
      "required": ["uid", "imageUrl", "overallScore", "features", "createdAt"]
    },
    "GlowUpRoadmap": {
      "title": "Glow-Up Roadmap",
      "description": "A personalized improvement strategy generated by ANA.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "analysisId": { "type": "string", "description": "Reference to the analysis used" },
        "phases": { "type": "array", "description": "Phased improvement plan" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Roadmap creation timestamp" }
      },
      "required": ["uid", "analysisId", "phases", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a conversation with ANA.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Who sent the message" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["uid", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/analyses/{analysisId}": {
      "schema": "FaceAnalysis",
      "description": "Facial analysis records."
    },
    "/roadmaps/{roadmapId}": {
      "schema": "GlowUpRoadmap",
      "description": "Personalized glow-up strategies."
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Individual chat messages with ANA."
    }
  }
}
